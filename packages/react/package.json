    "./auto-pages/client-entry": {
      "default": "./auto-pages/client-entry.js"
    },
    "./auto-pages/server-entry": {
      "default": "./auto-pages/server-entry.js"
    },
    "./auto-pages/serve": {
      "default": "./auto-pages/serve.js"
    }
  },
  "devDependencies": {
    "@faasjs/types": ">=8.0.0-beta.21",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "@faasjs/types": ">=8.0.0-beta.21"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
