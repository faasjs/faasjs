  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faasjs/faasjs.git",
    "directory": "packages/react"
  },
  "funding": "https://github.com/sponsors/faasjs",
  "files": [
    "dist",
    "auto-pages",
    "routing"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "default": "./dist/routing.mjs"
    },
    "./routing/client": {
      "types": "./dist/routing_client.d.ts",
      "default": "./dist/routing_client.mjs"
    },
    "./routing/server": {
      "types": "./dist/routing_server.d.ts",
      "default": "./dist/routing_server.mjs"
    },
    "./routing/client-entry": {
      "default": "./routing/client-entry.js"
    },
    "./routing/server-entry": {
      "default": "./routing/server-entry.js"
    },
    "./routing/serve": {
      "default": "./routing/serve.js"
