{
  "excludePrivate": true,
  "excludeExternals": true,
  "exclude": ["**/__tests__/**", "**/dist/**"],
  "plugin": ["typedoc-plugin-markdown"],
  "groupOrder": ["Functions", "Classes", "*"],
  "githubPages": false,
  "cleanOutputDir": false,
  "disableSources": true,
  "compilerOptions": {
    "skipLibCheck": true
  },
  "readme": "none",
  "hideGenerator": true
}
