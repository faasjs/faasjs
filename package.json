{
  "name": "faasjs-mono",
  "version": "8.0.0-beta.45",
  "private": true,
  "description": "A Rails-inspired, curated full-stack TypeScript framework for database-driven React business applications.",
  "workspaces": [
    "packages/*",
    "docs",
    "templates/*",
    "benchmarks"
  ],
  "type": "module",
  "scripts": {
    "lint": "vp check --fix *",
    "test": "vp test run",
    "ci": "vp test run --silent --coverage",
    "pack": "vp pack",
    "pub": "npm run clean && vp pack && npm run doc && node publish.ts",
    "doc": "node packages/docgen/src/cli.ts all",
    "clean": "rm -rf packages/*/dist coverage packages/*/*.log tmp *.log",
    "upgrade": "rm -rf packages/*/node_modules node_modules package-lock.json && npm install"
  },
  "devDependencies": {
    "@vitest/coverage-v8": ">=4.1.10",
    "typescript": ">=7.0.2",
    "vite-plus": ">=0.2.5"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core"
  },
  "engines": {
    "node": ">=26.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@12.0.1"
}
