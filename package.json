{
  "name": "faasjs-mono",
  "version": "8.0.0-beta.18",
  "private": true,
  "workspaces": [
    "packages/*",
    "docs",
    "examples/*",
    "benchmarks"
  ],
  "type": "module",
  "scripts": {
    "test": "vp test run",
    "ci": "vp test run --silent --coverage",
    "pub": "vp pack && vp run doc && node publish.ts",
    "doc": "node build-docs.ts && node sync-skill-references.ts && vp check --fix",
    "clean": "rm -rf packages/*/node_modules packages/*/dist coverage packages/*/*.log tmp *.log",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "*",
    "@vitejs/plugin-react": "*",
    "typedoc": "*",
    "typedoc-plugin-markdown": "*",
    "vite-plus": "*"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core",
    "vitest": "npm:@voidzero-dev/vite-plus-test"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.12.0"
}
