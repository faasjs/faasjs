{
  "name": "faasjs-mono",
  "version": "8.0.0-beta.14",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "vp check --fix",
    "test": "vp test run",
    "pack": "vp pack",
    "pub": "vp run build && vp run build:doc && vp check --fix && node publish.ts",
    "clean": "rm -rf packages/*/node_modules packages/*/dist coverage packages/*/*.log tmp *.log",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/node": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "jsdom": "latest",
    "typedoc": "latest",
    "typedoc-plugin-markdown": "latest",
    "typescript": "latest",
    "vite-plus": "latest",
    "vite-tsconfig-paths": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.8.0"
}
